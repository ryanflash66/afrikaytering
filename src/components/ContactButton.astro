---
import Icon from './Icon.astro'

interface Props {
  icon: string
  label: string
  href: string
  tone?: 'accent' | 'subtle'
}
const { icon, label, href, tone = 'accent' } = Astro.props
---

<a
  class:list={['contact-btn', { 'contact-btn--subtle': tone === 'subtle' }]}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <Icon name={icon} size={19} />{label}
</a>
