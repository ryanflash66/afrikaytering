---
interface Tab {
  id: string
  label: string
}
interface Props {
  tabs: Tab[]
}
const { tabs } = Astro.props
---

<nav class="catnav" aria-label="Menu sections" data-catnav>
  <ul class="catnav__list">
    {tabs.map((t, i) => (
      <li>
        <a
          class="catnav__tab"
          href={`#${t.id}`}
          data-tab={t.id}
          aria-current={i === 0 ? 'true' : undefined}
        >{t.label}</a>
      </li>
    ))}
  </ul>
</nav>
