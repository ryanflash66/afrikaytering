---
import Icon from './Icon.astro'

interface Props {
  tag: string
  size?: 'sm' | 'md'
}
const { tag, size = 'md' } = Astro.props

const TAGS: Record<string, { label: string; icon: string; palette: string }> = {
  vegetarian: { label: 'Vegetarian', icon: 'leaf', palette: 'green' },
  vegan: { label: 'Vegan', icon: 'sprout', palette: 'green' },
  halal: { label: 'Halal', icon: 'moon-star', palette: 'blue' },
  'gluten-free': { label: 'Gluten-free', icon: 'wheat-off', palette: 'mauve' },
  'dairy-free': { label: 'Dairy-free', icon: 'milk-off', palette: 'mauve' },
  'contains-nuts': { label: 'Contains nuts', icon: 'bean', palette: 'gold' },
  spicy: { label: 'Spicy', icon: 'flame', palette: 'clay' },
}

const info = TAGS[tag] ?? { label: tag, icon: 'leaf', palette: 'green' }
const sm = size === 'sm'
---

<span class:list={['diet', `diet--${info.palette}`, { 'diet--sm': sm }]}>
  <Icon name={info.icon} size={sm ? 12 : 13} />{info.label}
</span>
