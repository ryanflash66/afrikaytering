---
import DietaryBadge from './DietaryBadge.astro'

interface Props {
  item: Record<string, any>
  currency: string
  featured?: boolean
}
const { item, currency, featured = false } = Astro.props

const price = typeof item.price === 'number' ? item.price : Number(item.price ?? 0)
const priceFmt = new Intl.NumberFormat('en-US', {
  style: 'currency',
  currency: currency || 'USD',
}).format(price)

const tags: string[] = Array.isArray(item.dietaryTags) ? item.dietaryTags : []
const unavailable = item.available === false
const classes = [
  'item',
  featured ? 'item--featured' : '',
  unavailable ? 'item--unavailable' : '',
].filter(Boolean).join(' ')
---

<article class={classes} id={`item-${item.slug}`}>
  {item.image ? (
    <img
      class="item-photo"
      src={item.image}
      alt={item.imageAlt || item.name}
      loading="lazy"
      decoding="async"
      width="86"
      height="86"
    />
  ) : (
    <div class="item-photo item-photo--placeholder" aria-hidden="true">🍽️</div>
  )}

  <div class="item-body">
    <div class="item-head">
      <h3 class="item-name">{item.name}</h3>
      <span class="item-price">{priceFmt}</span>
    </div>
    {item.description && <p class="item-desc">{item.description}</p>}
    {tags.length > 0 && (
      <ul class="badges">
        {tags.map((t) => (
          <li><DietaryBadge tag={t} /></li>
        ))}
      </ul>
    )}
  </div>
</article>
