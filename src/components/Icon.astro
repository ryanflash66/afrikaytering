---
/*
 * Icon — inline Lucide SVGs (build-time, no client JS).
 * Geometry copied verbatim from lucide-static v1.x so the marks match the
 * Afrikaytering design system exactly. Decorative by default (aria-hidden);
 * pass `label` to expose an accessible name.
 */
interface Props {
  name: string
  size?: number
  strokeWidth?: number
  label?: string
  class?: string
}
const { name, size, strokeWidth = 2, label, class: className = '' } = Astro.props

const ICONS: Record<string, string> = {
