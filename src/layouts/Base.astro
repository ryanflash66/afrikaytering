---
import '../styles/global.css'
import Icon from '../components/Icon.astro'
import ContactButton from '../components/ContactButton.astro'

interface Props {
  restaurant: Record<string, any> | null
}
const { restaurant } = Astro.props
const r = restaurant ?? {}

const title = r.name ? `${r.name} — Menu` : 'Menu'
const description = r.tagline ?? 'Browse our menu'
const tel = String(r.phone ?? '').replace(/\s+/g, '')
const wa = String(r.whatsapp ?? '').replace(/[^0-9]/g, '')
const maps = r.mapsUrl
const lockup = '/images/brand/logo-full-gold.png'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fbf8f1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={lockup} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <img
          class="brand-lockup"
          src={lockup}
          alt={`${r.name ?? 'Afrikaytering'} — Catering and Food Display`}
          width="112"
          height="120"
        />
        <h1 class="sr-only">{r.name ?? 'Afrikaytering'}{r.tagline ? ` — ${r.tagline}` : ''}</h1>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="site-footer__inner">
        <img class="footer-lockup" src={lockup} alt="" aria-hidden="true" width="112" height="120" />

        {(tel || wa || maps) && (
          <div class="contact-row">
            {tel && <ContactButton icon="phone" label="Call" href={`tel:${tel}`} />}
            {wa && <ContactButton icon="message-circle" label="WhatsApp" href={`https://wa.me/${wa}`} />}
            {maps && <ContactButton icon="navigation" label="Directions" href={maps} tone="subtle" />}
          </div>
        )}

        {r.hours && (
          <div class="footer-meta">
            <Icon name="clock" size={17} class="footer-meta__icon" />
            <span class="footer-meta__text">{r.hours}</span>
          </div>
        )}
        {r.address && (
          <div class="footer-meta">
            <Icon name="map-pin" size={17} class="footer-meta__icon" />
            <span class="footer-meta__text">{r.address}</span>
          </div>
        )}

        {(r.instagram || r.facebook) && (
          <div class="footer-social">
            {r.instagram && <a href={r.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>}
            {r.facebook && <a href={r.facebook} target="_blank" rel="noopener noreferrer">Facebook</a>}
          </div>
        )}

        <p class="footer-note">Menu for viewing only. To place an order, please speak with our team.</p>
      </div>
    </footer>
  </body>
</html>
